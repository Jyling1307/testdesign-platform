# TestDesignAI Platform - Environment Configuration Template
# 复制本文件为 .env 并填入真实 API key

# Django compat（FastAPI 下不用，保留兼容）
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=*

# LLM（智谱 GLM，Anthropic 兼容接口）
# 申请：https://open.bigmodel.cn/
LLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
LLM_API_KEY=your-zhipuai-api-key-here
LLM_MODEL=glm-5-turbo

# Embedding（硅基流动 bge-m3）
# 申请：https://siliconflow.cn/
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/
EMBEDDING_API_KEY=your-siliconflow-api-key-here
EMBEDDING_MODEL=BAAI/bge-m3

# Rerank（硅基流动 bge-reranker-v2-m3，与 embedding 同账号）
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
